# .env.example — Copy this to .env and fill in your values
# Environment variables for the Travel Health Advisory System

# Flask Configuration
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_KEY
DEBUG=False
TESTING=False

# Session Security (set to True in production with HTTPS)
SESSION_COOKIE_SECURE=False

# Database settings for MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=travel_health_advisory

# Logging
LOG_LEVEL=INFO

# API Keys (optional)
OPENWEATHER_API_KEY=YOUR_API_KEY
